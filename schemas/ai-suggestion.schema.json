{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerly.local/schemas/ai-suggestion.schema.json",
  "title": "AiSuggestionOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "suggestedCategoryCode", "alternatives", "evidenceReferenceIds", "reasonCodes", "confidenceBand", "founderQuestion", "requiresFounderReview", "requiresAccountantReview", "explanation"],
  "properties": {
    "outcome": {"enum": ["suggestion", "insufficient_evidence", "refusal"]},
    "suggestedCategoryCode": {"type": ["string", "null"]},
    "alternatives": {"type": "array", "maxItems": 5, "items": {"type": "string"}},
    "evidenceReferenceIds": {"type": "array", "maxItems": 20, "items": {"type": "string"}},
    "reasonCodes": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"enum": ["merchant_context", "description_context", "amount_pattern", "historical_context", "deterministic_conflict", "insufficient_business_context", "high_risk_accounting", "unsupported_case"]}},
    "confidenceBand": {"enum": ["unknown", "low", "medium", "high"]},
    "founderQuestion": {"type": ["string", "null"], "maxLength": 300},
    "requiresFounderReview": {"const": true},
    "requiresAccountantReview": {"type": "boolean"},
    "explanation": {"type": "string", "minLength": 1, "maxLength": 800}
  }
}
